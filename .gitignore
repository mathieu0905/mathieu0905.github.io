# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# arxiv daily temp
.arxiv-today.txt

# Paper PDFs are synced locally from ../mypaper via scripts/sync-papers.mjs
# (only files listed in src/data/papers.ts are copied). Keep PDFs out of git by
# default — already-tracked PDFs remain tracked; new accepted PDFs require
# explicit `git add -f public/papers/<name>.pdf` to avoid "opening champagne"
# on under-review drafts.
public/papers/*.pdf

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
